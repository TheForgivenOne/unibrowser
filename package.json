{
  "name": "unibrowser",
  "version": "0.1.0",
  "description": "Headless cross-browser E2E testing with full type safety | Docs: https://theforgivenone.github.io/unibrowser/",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "pyi"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run tests/e2e",
    "pyright": "pyright",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "headless",
    "browser",
    "testing",
    "e2e",
    "playwright",
    "cross-browser"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheForgivenOne/unibrowser.git"
  },
  "bugs": {
    "url": "https://github.com/TheForgivenOne/unibrowser/issues"
  },
  "homepage": "https://theforgivenone.github.io/unibrowser/",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "dependencies": {
    "playwright": "^1.48.0",
    "playwright-core": "^1.48.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pngjs": "^6.0.5",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^10.1.0",
    "pngjs": "^7.0.0",
    "typescript": "^5.6.0",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.0"
  }
}
